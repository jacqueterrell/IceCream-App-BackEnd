# Copy this file to .env and set your key.
# Required for getOptimizedRoute (Directions API).
#
# If you get "Request Denied" from Maps API:
# 1. Enable "Directions API": https://console.cloud.google.com/apis/library/directions-backend.googleapis.com
# 2. Use a key that allows Directions API: APIs & Services > Credentials > your key >
#    Application restrictions: None (or add "Cloud Functions" / your function URL if you restrict).
#    API restrictions: Restrict key > select "Directions API" (and any other Maps APIs you use).
# 3. Billing: Enable billing on the project (Directions API needs it). https://console.cloud.google.com/billing
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
